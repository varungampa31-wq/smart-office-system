# Copy this file to backend/.env for local runs (docker-compose reads
# these same variable names too -- see the root docker-compose.yml).

DJANGO_SECRET_KEY=change-me-to-something-random-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Leave unset to use local SQLite. Set for Postgres, e.g.
# postgres://smartoffice:smartoffice@db:5432/smartoffice
DATABASE_URL=

# Shared secret the fog node must send as the X-API-Key header when
# calling POST /api/sensors/ingest/. Must match fog_node/.env's
# FOG_INGEST_API_KEY.
FOG_INGEST_API_KEY=dev-fog-api-key-change-me

# Celery / Redis (the ingestion queue). docker-compose: use the service
# name, e.g. redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
# Set True to run Celery tasks synchronously in-process (no worker/Redis
# needed) -- handy for a quick demo but doesn't exercise the real queue.
CELERY_TASK_ALWAYS_EAGER=False

TEMPERATURE_ALERT_MAX_C=30
HUMIDITY_ALERT_MAX_PCT=70
