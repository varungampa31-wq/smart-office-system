# docker-compose: use the service name, e.g. http://fog_node:9000
FOG_NODE_URL=http://localhost:9000

RFID_INTERVAL_SECONDS=8
TEMPERATURE_INTERVAL_SECONDS=4
HUMIDITY_INTERVAL_SECONDS=6
OCCUPANCY_INTERVAL_SECONDS=5
DOOR_INTERVAL_SECONDS=10

KNOWN_RFID_TAGS=RFID-A1001,RFID-A1002,RFID-A1003,RFID-A1004,RFID-A1005
INVALID_RFID_PROBABILITY=0.15

TEMPERATURE_BASELINE_C=22.0
TEMPERATURE_SPIKE_PROBABILITY=0.1
HUMIDITY_BASELINE_PCT=45.0
HUMIDITY_SPIKE_PROBABILITY=0.1
