FOG_NODE_ID=fog-01
FOG_HOST=0.0.0.0
FOG_PORT=9000

# Where the Django backend is reachable from this fog node.
# docker-compose: use the service name, e.g. http://backend:8000
BACKEND_URL=http://localhost:8000

# Must match FOG_INGEST_API_KEY in backend/.env
FOG_INGEST_API_KEY=dev-fog-api-key-change-me

DISPATCH_INTERVAL_SECONDS=5
FOG_MAX_BATCH_SIZE=200
TEMPERATURE_NOISE_BAND_C=0.2
FOG_HTTP_TIMEOUT_SECONDS=5
FOG_HTTP_RETRY_ATTEMPTS=3
